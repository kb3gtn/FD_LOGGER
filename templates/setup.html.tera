<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FD Logger – Setup</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'Segoe UI', system-ui, sans-serif;
  background: #0d1117;
  color: #e6edf3;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}
.setup-wrap {
  background: #161b22;
  border: 1px solid #30363d;
  border-radius: 8px;
  padding: 2rem;
  width: 100%;
  max-width: 480px;
}
h1 { font-size: 1.5rem; margin-bottom: 0.5rem; color: #58a6ff; }
.subtitle { color: #8b949e; margin-bottom: 1.5rem; font-size: 0.9rem; }
.form-group { margin-bottom: 1.2rem; }
label { display: block; font-size: 0.85rem; font-weight: 600; color: #8b949e; margin-bottom: 0.35rem; text-transform: uppercase; letter-spacing: 0.05em; }
input[type=text] {
  width: 100%;
  padding: 0.55rem 0.75rem;
  background: #0d1117;
  border: 1px solid #30363d;
  border-radius: 6px;
  color: #e6edf3;
  font-size: 1rem;
  transition: border-color 0.15s;
}
input[type=text]:focus { outline: none; border-color: #58a6ff; }
.hint { color: #8b949e; font-size: 0.78rem; margin-top: 0.3rem; }
.btn-submit {
  width: 100%;
  padding: 0.7rem;
  background: #238636;
  color: #fff;
  border: none;
  border-radius: 6px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  margin-top: 0.5rem;
  transition: background 0.15s;
}
.btn-submit:hover { background: #2ea043; }
</style>
</head>
<body>
<div class="setup-wrap">
  <h1>🎙 Field Day Logger</h1>
  <p class="subtitle">Enter your station information to begin logging contacts.</p>

  <form method="POST" action="/setup">
    <div class="form-group">
      <label>Station Callsign</label>
      <input type="text" name="callsign" required autocomplete="off" autocorrect="off"
             autocapitalize="characters" spellcheck="false"
             placeholder="e.g. W1AW"
             value="{{ existing.callsign | default(value='') }}">
      <p class="hint">The callsign this field day site is operating under</p>
    </div>

    <div class="form-group">
      <label>Class</label>
      <input type="text" name="class" required autocomplete="off"
             autocapitalize="characters" spellcheck="false"
             placeholder="e.g. 4A"
             value="{{ existing.class | default(value='') }}">
      <p class="hint">Number followed by A–F (e.g. 4A, 1B, 10A)</p>
    </div>

    <div class="form-group">
      <label>Section</label>
      <input type="text" name="section" required autocomplete="off"
             autocapitalize="characters" spellcheck="false"
             placeholder="e.g. MDC"
             value="{{ existing.section | default(value='') }}">
      <p class="hint">Your ARRL/RAC field day section abbreviation</p>
    </div>

    <button type="submit" class="btn-submit">Start Logging</button>
  </form>
</div>
</body>
</html>
